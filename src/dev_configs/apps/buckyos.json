{
  "name": "buckyos",
  "version": "0.6.0",
  "directories": {
      "source": "/opt/buckyosvm/current",
      "target": "/opt/buckyos",
      "source_bin": "/opt/buckyosvm/base/bin",
      "target_bin": "/opt/buckyos/bin"
  },
  "commands": {
    "build": [
      "echo 'Run uv run ./build_for_vm_test.py before buckyos-devtest install/update'"
    ],
    "build_all": [
      "uv run ./build_for_vm_test.py --skip-build --skip-install --node-group {{buckyos.node_group}}"
    ],
    "update":[
      "echo 'update buckyos'"
    ],
    "install": [
      "sudo chmod 777 -R /opt/buckyos/bin/",
      "sudo cp /opt/buckyos/etc/ca.cert /usr/local/share/ca-certificates/buckyos_ca.crt",
      "sudo chmod 644 /usr/local/share/ca-certificates/buckyos_ca.crt",
      "sudo update-ca-certificates"
    ],
    "start": ["sudo nohup /opt/buckyos/bin/node-daemon/node_daemon --enable_active > /dev/null 2>&1 &"],
    "stop": ["sudo python3 /opt/buckyos/bin/stop.py"],
    "check_dns": ["cat {{sn.ip}}"]
  }
}
