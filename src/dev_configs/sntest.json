{
    "nodes": {
      "sn": {
        "node_id": "sn",
        "vm_template": "ubuntu_sn",
        "vm_params": {
          "disk": "8G"
        },
        "network": {
          "lan_id": "wan",
          "type": "bridge"
        },
        "apps": {
          "web3-gateway": {
            "node_group_name": "sn_server"
          }
        },
        "init_commands": [
          "sudo hostnamectl set-hostname sn",
          "sudo mkdir -p /opt/web3-gateway",
          "sudo chown -R ubuntu:ubuntu /opt/web3-gateway",
          "sudo iptables -I INPUT -p udp --dport 53 -j ACCEPT",
          "sudo iptables -I INPUT -p tcp --dport 53 -j ACCEPT"
        ],
        "instance_commands": [
            "sudo sh -c \"echo '{{sn.ip}} sn.devtests.org' >> /etc/hosts\""
          ],
        "directories": {
          "logs": "/opt/buckyos/logs"
        }
      },
    
      "alice-ood1": {
        "node_id": "alice_ood1",
        "vm_template": "ubuntu_basic",
        "vm_params": {
          "disk": "10G"
        },
        "network": {
          "lan_id": "lan",
          "type": "nat"
        },
        "apps": {
          "buckyos" : {
            "node_group": "alice.ood1"
          }
        },
        "init_commands": [
          "hostnamectl set-hostname alice-ood1",
          "sudo mkdir -p /opt/buckyos",
          "sudo chown -R ubuntu:ubuntu /opt/buckyos",
          "sudo iptables -I INPUT 1 -i lo -j ACCEPT",
          "sudo iptables -I INPUT 2 ! -i lo -p tcp -m multiport --dports 80,443,2980 -j REJECT"
        ],
        "instance_commands": [
            "sudo mkdir -p /etc/systemd/resolved.conf.d",
            "sudo sh -c \"echo '[Resolve]\\nDNS={{sn.ip}}\\nDomains=~devtests.org\\nFallbackDNS=8.8.8.8 1.1.1.1' > /etc/systemd/resolved.conf.d/buckyos-dns.conf\"",
            "sudo systemctl restart systemd-resolved"
        ],
        "directories": {
          "logs": "/opt/buckyos/logs"
        }
      }
    },
    "instance_order": ["sn", "alice-ood1"]
  }
